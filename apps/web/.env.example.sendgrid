# SendGrid Configuration for Contact Form Email Integration
#
# To enable email sending for the contact form:
# 1. Create a SendGrid account at https://sendgrid.com
# 2. Generate an API key from Settings > API Keys
# 3. Add the following variables to your .env.local file

# SendGrid API Key (required for email sending)
SENDGRID_API_KEY=sg_

# Sender email address (required for email sending)
# This must be a verified sender in your SendGrid account
SENDGRID_FROM_EMAIL=noreply@agritrace.com

# Recipient email address (optional, defaults to aniekan@qlfgroup.ng)
# Contact form submissions will be sent to this email
SENDGRID_TO_EMAIL=aniekan@qlfgroup.ng

# Notes:
# - Without SENDGRID_API_KEY, contact form submissions will only be logged to console
# - With SENDGRID_API_KEY and SENDGRID_FROM_EMAIL, emails will be sent automatically
# - The SENDGRID_FROM_EMAIL must be verified as a sender in SendGrid dashboard
