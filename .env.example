# ── Supabase / Postgres ─────────────────────────────────────
# Find this in: Supabase dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ── Africa's Talking ─────────────────────────────────────────
# Sandbox credentials from africastalking.com
AT_API_KEY="your_africastalking_api_key"
AT_USERNAME="sandbox"              # use "sandbox" for testing

# ── Polygon / Blockchain ──────────────────────────────────────
# Alchemy or Infura Amoy testnet RPC URL
POLYGON_RPC_URL="https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY"
DEPLOYER_PRIVATE_KEY="0x..."       # testnet wallet private key — NEVER commit real keys

# ── API Server ────────────────────────────────────────────────
PORT=3001

# ── Web App ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
